/* CyberStore - Layout & Structure Styles */

/* ── Sidebar ── */
#sidebar {
    padding: 1 0;
}

/* ── Search Bar ── */
#search-bar {
    padding: 0 1;
}

/* ── Breadcrumb ── */
#breadcrumb {
    padding: 0 1;
}

/* ── Object Table Header ── */
DataTable > .datatable--header {
    text-style: bold;
}

/* ── Status Bar ── */
#status-bar {
    height: 1;
}

/* ── Progress Bar ── */
ProgressBar {
    margin-bottom: 1;
    padding: 0 1;
}
